---
const { step, title, text } = Astro.props;
---
<div class="timeline-step flex flex-col items-center relative h-full">
  <div class="timeline-stem hidden md:block">
    <div class="timeline-dot"></div>
  </div>
  <div class="timeline-card mt-0 md:mt-6 bg-[#e1c4afc3] border-2 border-[#c4916e] rounded-[14px] p-4 md:py-5 md:px-[18px] w-full md:w-[90%] flex-1">
    <span class="timeline-number inline-block text-xs font-bold text-[#faf5ee] uppercase tracking-[0.08em] bg-[#7a4e38] py-[3px] px-[10px] rounded-[20px] mb-[10px]">{step} pas</span>
    <h3 class="timeline-title text-[0.95rem] md:text-[1.3rem] font-bold text-[#4a3728] mb-2 tracking-[-0.01em] leading-[1.3]">{title}</h3>
    <p class="timeline-text text-[0.85rem] md:text-[1.1rem] text-[#5a4a3a] leading-[1.6]">{text}</p>
  </div>
</div>