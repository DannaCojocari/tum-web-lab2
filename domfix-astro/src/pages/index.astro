---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TimelineStep from '../components/TimelineStep.astro';
import PortfolioItem from '../components/PortfolioItem.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.astro';
import AboutFeature from '../components/AboutFeature.astro';
// ── Settings ─────────────────────────────────────────────────────────────────
import hero      from '../content/settings/hero.json';
import about     from '../content/settings/about.json';
import servicesData  from '../content/settings/services.json';
import portfolioData from '../content/settings/portfolio.json';

const services  = servicesData.items.sort((a, b) => a.order - b.order);
const portfolio = portfolioData.items.sort((a, b) => a.order - b.order);
---
<Layout>
  <Navbar />

  <!-- Dark overlay for mobile nav drawer -->
  <div class="nav-overlay" id="nav-overlay"></div>

  <section class="hero">
    <div class="hero-background">
      <img src="photos/background.png" alt="DomFix- renovări profesionale" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container max-w-[90%] mx-auto px-5">
      <div class="hero-content">
        <div class="hero-text">
          <h2 class="hero-title">{hero.title}</h2>
          <p class="subheadline">{hero.subtitle}</p>
          <div class="cta-group flex gap-4 mt-3 flex-wrap">
            <a href={hero.cta_primary_href} class="btn btn-primary">
              {hero.cta_primary_text}
              <img src="photos/right-up.png" alt="arrow" class="btn-arrow">
            </a>
            <a href={hero.cta_secondary_href} class="btn btn-secondary">
              {hero.cta_secondary_text}
              <img src="photos/right-up.png" alt="arrow" class="btn-arrow">
            </a>
          </div>
        </div>
        <div class="hero-form flex justify-end items-start">
          <div class="form-container">
            <h3 class="form-title">Obține o consultație gratuită</h3>
            <p class="form-subtitle">Completează formularul și te vom contacta în cel mai scurt timp</p>
            <form class="consultation-form" action="#" method="POST">
              <div class="form-group">
                <div class="input-wrapper">
                  <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <input type="text" id="name" name="name" placeholder="Numele tău" required>
                </div>
              </div>
              <div class="form-group">
                <div class="input-wrapper">
                  <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  <input type="email" id="email" name="email" placeholder="Email" required>
                </div>
              </div>
              <div class="form-group">
                <div class="input-wrapper" id="phone-wrapper">
                  <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.88a16 16 0 0 0 6.21 6.21l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  <input type="tel" id="phone" name="phone" placeholder="Telefon" inputmode="tel" pattern="[\+]?[0-9\s\-]{9,17}" required autocomplete="tel">
                </div>
                <span class="phone-error" id="phone-error">Introduceți doar cifre, spații sau +</span>
              </div>
              <div class="form-group">
                <div class="input-wrapper">
                  <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  <select id="service" name="service" required>
                    <option value="">Tipul de serviciu</option>
                    <option value="renovation">Renovări generale</option>
                    <option value="interior">Finisaje interioare</option>
                    <option value="kitchen">Renovare bucătărie</option>
                    <option value="bathroom">Renovare baie</option>
                    <option value="other">Altele</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <div class="input-wrapper input-wrapper--textarea">
                  <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  <textarea id="message" name="message" placeholder="Mesaj (opțional)..." rows="3"></textarea>
                </div>
              </div>
              <button type="submit" class="btn btn-form">
                Trimite cererea
                <img src="photos/right-up.png" alt="arrow" class="btn-arrow">
              </button>
            </form>
            <div class="form-confirmation" id="form-confirmation">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="confirmation-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <h4>Cererea a fost trimisă!</h4>
              <p>Vă vom contacta în cel mai scurt timp.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile-only stats banner (hidden on desktop) -->
  <section class="mobile-hero-banner mobile-only">
    <div class="container max-w-[90%] mx-auto px-5">
      <p class="mobile-banner-tagline">Partenerul tău de încredere în renovări</p>
        <div class="mobile-banner-stats flex justify-center mb-6">
        <div class="mobile-stat"><strong>500+</strong><span>Proiecte finalizate</span></div>
        <div class="mobile-stat"><strong>10+</strong><span>Ani experiență</span></div>
        <div class="mobile-stat"><strong>100%</strong><span>Satisfacție garantată</span></div>
      </div>
      <a href="#services" class="btn btn-mobile-banner">Descoperă serviciile noastre</a>
    </div>
  </section>

  <section class="services py-[100px] px-5 scroll-mt-[100px]" id="services">
    <div class="container max-w-[90%] mx-auto px-5">
      <div class="services-header text-center max-w-[800px] mx-auto mb-20">
        <h2 class="services-title text-[3rem] font-bold text-[#4a3728] mb-5 tracking-[-0.02em]">Serviciile noastre</h2>
        <p class="services-description text-xl text-[#8b6b55] leading-[1.6]">
          Noi oferim servicii complete de renovare și construcție pentru a transforma spațiul tău în visul pe care ți-l dorești.
        </p>
      </div>

      <div class="services-grid grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
        {services.map((s) => (
          <ServiceCard
            number={s.order}
            title={s.title}
            image={s.image}
            alt={s.alt}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="process py-[5vw] px-[4vw] md:py-[3vh] md:px-[1.5vw] bg-[#f0e6d8] m-[2%] md:m-[1%] rounded-[20px] scroll-mt-[76px] md:scroll-mt-[100px]" id="process">
    <div class="container max-w-[90%] mx-auto px-5">

      <!-- Top: title + description left, image right -->
      <div class="process-top grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 items-stretch mb-7 md:mb-10">
        <div class="process-top-text flex flex-col justify-center pr-3">
            <h2 class="process-title text-[1.2rem] md:text-[2.5rem] font-bold text-[#4a3728] mb-[10px] tracking-[-0.02em] leading-[1.2]">Procesul de renovare</h2>
          <p class="process-description text-[0.8rem] md:text-[1.2rem] text-[#5a4a3a] leading-[1.5]">
            Fiecare proiect este gestionat profesional, de la planificare până la finalizare,
            pentru a asigura rezultate de calitate și satisfacția completă a clientului.
          </p>
        </div>
        <div class="process-image w-full h-[200px] md:h-[30vh] rounded-xl md:rounded-2xl overflow-hidden">
            <img src="photos/process.png" alt="Procesul de renovare" class="w-full h-full object-cover">
        </div>
      </div>

      <!-- Bottom: horizontal timeline -->
      <div class="process-timeline px-5 pb-5">
<div class="timeline-track grid grid-cols-1 md:grid-cols-4 items-stretch relative gap-4 md:gap-0">

          <TimelineStep step={1} title="Planificare și evaluare" text="Se analizează spațiul, se stabilesc lucrările necesare, bugetul și materialele." />
          <TimelineStep step={2} title="Pregătirea și lucrările de bază" text="Se îndepărtează elementele vechi și se execută lucrările structurale și instalațiile necesare." />
          <TimelineStep step={3} title="Finisaje și montaj" text="Se realizează finisajele interioare și se montează pardoselile, ușile și elementele decorative." />
          <TimelineStep step={4} title="Verificare și finalizare" text="Se montează echipamentele finale, se fac verificările și curățenia, iar spațiul devine gata de utilizare." />
        </div>
      </div>

    </div>
  </section>

  <section class="portfolio" id="portfolio">
    <div class="container max-w-[90%] mx-auto px-5">
      <div class="portfolio-header text-center max-w-[800px] mx-auto mb-[60px]">
        <h2 class="portfolio-title">Lucrările noastre</h2>
        <p class="portfolio-description">
          Explorează o selecție din proiectele noastre finalizate și descoperă 
          calitatea execuției și atenția la detalii care ne definesc.
        </p>
      </div>

      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <PortfolioItem
            image={p.image}
            alt={p.alt}
            title={p.title}
            size={p.size}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="about" id="about">
    <div class="container max-w-[90%] mx-auto px-5">
      <!-- Header: title + subtitle left-aligned -->
      <div class="about-header text-left mb-12">
        <h2 class="about-title">{about.title}</h2>
        <p class="about-intro">{about.intro}</p>
      </div>

      <div class="about-layout grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-[60px] items-start mx-auto">
        <!-- Left Side: Image -->
        <div class="about-left md:pr-5">
          <div class="about-image">
            <img src="photos/team.png" alt="Echipa DomFix">
          </div>
        </div>

        <!-- Right Side: Features + CTA -->
        <div class="about-right md:pl-5">
          <div class="about-features flex flex-col gap-[30px] mb-10">
            <AboutFeature title="Experiență și profesionalism" text="Echipa noastră de specialiști autorizați aduce expertiză în fiecare proiect, de la cele mai simple renovări până la transformări complete." />
            <AboutFeature title="Calitate garantată" text="Folosim doar materiale de calitate superioară și oferim garanție pentru toate lucrările executate, asigurând durabilitate pe termen lung." />
            <AboutFeature title="Transparență totală" text="Comunicăm deschis pe tot parcursul proiectului, oferind rapoarte detaliate și respectând bugetul și termenele stabilite." />
            <AboutFeature title="Satisfacția clientului" text="Peste 500 de proiecte finalizate cu succes și clienți mulțumiți care ne recomandă cu încredere. Satisfacția ta este prioritatea noastră." />
          </div>

          <div class="about-cta mt-5">
            <a href="tel:+37376009015" class="btn btn-primary">
              Contactează-ne acum
              <img src="photos/right-up.png" alt="arrow" class="btn-arrow">
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal Structure -->
  <div id="serviceModal" class="modal fixed inset-0 z-[2000] bg-black/70 backdrop-blur-[5px]">
    <div class="modal-content bg-[#faf5ee] fixed bottom-0 left-0 right-0 md:relative md:bottom-auto md:left-auto md:right-auto md:mx-auto md:my-[5%] p-6 md:py-10 md:px-[50px] rounded-t-[20px] md:rounded-[20px] max-w-full md:max-w-[70vw] max-h-[88vh] md:max-h-[80vh] overflow-y-auto shadow-[0_10px_40px_rgba(0,0,0,0.3)]">
      <span class="modal-close absolute top-5 right-6 text-[35px] font-light text-[#a08060] cursor-pointer leading-none transition-colors duration-300">&times;</span>
      <div id="modalBody"></div>
    </div>
  </div>

  <!-- Lightbox for Portfolio Images -->
  <div id="lightbox" class="lightbox">
    <span class="lightbox-close">&times;</span>
    <img class="lightbox-content" id="lightboxImage">
  </div>

  <script type="application/json" id="service-data" set:html={JSON.stringify(services)} />

  <script>
    // Phone field validation
    (function () {
      const phoneInput = document.getElementById('phone');
      const phoneError = document.getElementById('phone-error');
      const phoneWrapper = document.getElementById('phone-wrapper');

      if (phoneInput) {
        phoneInput.addEventListener('input', function () {
          // Strip any character that is not digit, +, space or dash
          const cleaned = this.value.replace(/[^\d\+\s\-]/g, '');
          if (this.value !== cleaned) {
            this.value = cleaned;
          }

          // Validate: must contain at least 9 digits
          const digits = cleaned.replace(/\D/g, '');
          if (cleaned.length > 0 && digits.length < 9) {
            phoneWrapper.classList.add('input-error');
            phoneError.classList.add('visible');
            phoneError.textContent = 'Numărul trebuie să conțină cel puțin 9 cifre.';
          } else if (cleaned.length > 0 && digits.length > 15) {
            phoneWrapper.classList.add('input-error');
            phoneError.classList.add('visible');
            phoneError.textContent = 'Numărul este prea lung (max 15 cifre).';
          } else {
            phoneWrapper.classList.remove('input-error');
            phoneError.classList.remove('visible');
          }
        });

        phoneInput.addEventListener('blur', function () {
          if (this.value.trim() === '') {
            phoneWrapper.classList.remove('input-error');
            phoneError.classList.remove('visible');
          }
        });
      }
    })();

    // Consultation form submit
    (function () {
      const form = document.querySelector('.consultation-form');
      const confirmation = document.getElementById('form-confirmation');

      if (form && confirmation) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();

          // Extra phone guard
          const phoneInput = document.getElementById('phone');
          const phoneWrapper = document.getElementById('phone-wrapper');
          const phoneError = document.getElementById('phone-error');
          const digits = phoneInput.value.replace(/\D/g, '');
          if (digits.length < 9) {
            phoneWrapper.classList.add('input-error');
            phoneError.classList.add('visible');
            phoneError.textContent = 'Numărul trebuie să conțină cel puțin 9 cifre.';
            phoneInput.focus();
            return;
          }

          // Show confirmation, hide form
          form.style.display = 'none';
          confirmation.classList.add('visible');

          // Reset after 4 seconds
          setTimeout(function () {
            form.reset();
            form.style.display = '';
            confirmation.classList.remove('visible');
            phoneWrapper.classList.remove('input-error');
            phoneError.classList.remove('visible');
          }, 4000);
        });
      }
    })();

    // Service details — injected at build time from services.json
    const serviceDetails = {};
    JSON.parse(document.getElementById('service-data').textContent)
      .forEach(s => { serviceDetails[s.order] = s; });

    // Get modal elements
    const modal = document.getElementById('serviceModal');
    const modalBody = document.getElementById('modalBody');
    const closeBtn = document.querySelector('.modal-close');

    // Open modal function
    function openModal(serviceId) {
      const service = serviceDetails[serviceId];
      
      let tasksHTML = service.tasks.map(task => `<li class="text-[0.9rem] md:text-[1.05rem] text-[#5a3e2b] leading-[1.8] py-2 pl-[10px]">— ${task}</li>`).join('');
      let benefitsHTML = service.benefits.map(benefit => `<li class="text-[0.9rem] md:text-[1.05rem] text-[#5a3e2b] leading-[1.8] py-2 pl-[10px]">— ${benefit}</li>`).join('');
      
      modalBody.innerHTML = `
        <h2 class="modal-title text-[1.3rem] md:text-[2rem] font-bold text-[#4a3728] mb-[10px] tracking-[-0.02em] pr-8 md:pr-0">${service.title}</h2>
        <p class="modal-subtitle text-[1rem] md:text-[1.25rem] text-[#8b6b55] italic mb-5 font-medium">${service.modal_subtitle}</p>
        <p class="modal-description text-[0.95rem] md:text-[1.1rem] text-[#5a3e2b] leading-[1.7] mb-[30px]">${service.modal_description}</p>
        
        <div class="modal-sections flex flex-col md:flex-row gap-5 md:gap-[30px] mt-5">
          <div class="modal-section flex-1">
            <h3 class="modal-section-title text-[1.1rem] md:text-[1.3rem] font-bold text-[#4a3728] mb-[15px]">Ce realizăm</h3>
            <ul class="modal-list list-none p-0 mb-5">${tasksHTML}</ul>
          </div>
          
          <div class="modal-section flex-1">
            <h3 class="modal-section-title text-[1.1rem] md:text-[1.3rem] font-bold text-[#4a3728] mb-[15px]">Beneficii</h3>
            <ul class="modal-list list-none p-0 mb-5">${benefitsHTML}</ul>
          </div>
        </div>
        
        <div class="modal-cta mt-10 text-center pt-[30px] border-t border-[#d4bfa8]">
          <a href="tel:+37376009015" class="modal-btn inline-block bg-[#6b4c38] text-[#faf5ee] py-3 md:py-4 px-6 md:px-10 text-[0.95rem] md:text-[1.1rem] font-semibold rounded-lg no-underline">Fă o programare</a>
        </div>
      `;
      
      modal.style.display = 'block';
      document.body.style.overflow = 'hidden';
    }

    // Close modal function
    function closeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = 'auto';
    }

    // Add click events to service cards
    document.querySelectorAll('.service-card[data-service]').forEach(card => {
      card.addEventListener('click', function() {
        const serviceId = this.getAttribute('data-service');
        openModal(serviceId);
      });
    });

    // Close modal when clicking X
    closeBtn.addEventListener('click', closeModal);

    // Close modal when clicking outside
    window.addEventListener('click', function(e) {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
      }
    });

    // Portfolio lightbox functionality
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImage');
    const lightboxClose = document.querySelector('.lightbox-close');
    const portfolioItems = document.querySelectorAll('.portfolio-item');

    // Open lightbox when clicking on portfolio item
    portfolioItems.forEach(item => {
      item.addEventListener('click', function() {
        const img = this.querySelector('img');
        
        lightbox.style.display = 'flex';
        lightboxImg.src = img.src;
        document.body.style.overflow = 'hidden';
      });
    });

    // Close lightbox when clicking X
    lightboxClose.addEventListener('click', function() {
      lightbox.style.display = 'none';
      document.body.style.overflow = 'auto';
    });

    // Close lightbox when clicking outside the image
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) {
        lightbox.style.display = 'none';
        document.body.style.overflow = 'auto';
      }
    });

    // Close lightbox with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox.style.display === 'flex') {
        lightbox.style.display = 'none';
        document.body.style.overflow = 'auto';
      }
    });

    // Mobile navigation hamburger toggle
    (function () {
      const hamburger = document.getElementById('nav-hamburger');
      const navMenu = document.getElementById('nav-menu');
      const overlay = document.getElementById('nav-overlay');

      function openMenu() {
        navMenu.classList.add('open');
        hamburger.classList.add('open');
        hamburger.setAttribute('aria-expanded', 'true');
        if (overlay) overlay.classList.add('active');
      }

      function closeMenu() {
        navMenu.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        if (overlay) overlay.classList.remove('active');
      }

      if (hamburger && navMenu) {
        hamburger.addEventListener('click', function () {
          navMenu.classList.contains('open') ? closeMenu() : openMenu();
        });

        // Close drawer, then let native anchor navigation scroll the page
        navMenu.querySelectorAll('a').forEach(function (link) {
          link.addEventListener('click', function () {
            closeMenu();
          });
        });

        // Close when clicking the overlay
        if (overlay) overlay.addEventListener('click', closeMenu);

        // Close with Escape key
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeMenu();
        });
      }
    })();
  </script>

  <!-- Mobile-only sticky CTA bar (hidden on desktop) -->
  <div class="mobile-sticky-cta mobile-only">
    <a href="tel:+37376009015" class="sticky-call">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.88a16 16 0 0 0 6.21 6.21l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Sună acum
    </a>
    <a href="#services" class="sticky-services">Serviciile noastre</a>
  </div>

  <Mascot />
  <Footer />
</Layout>